package builtin

import (
	"fmt"
	"os"
	"strconv"
	"strings"
)

func init() {
	Register("echo", Echo, "Echo arguments (supports -n/-e/-E and redirection)")
}

// Echo implements a minimal echo(1) for the agent.
// Supported flags:
//   -n   : do not output the trailing newline
//   -e   : enable interpretation of backslash escapes
//   -E   : disable interpretation of backslash escapes (default)
func Echo(args []string) int {
	newline := true
	escapes := false

	// Parse flags like POSIX echo: a sequence of flags at the start is allowed
	i := 0
	for i < len(args) && len(args[i]) > 1 && args[i][0] == '-' {
		switch args[i] {
		case "-n":
			newline = false
		case "-e":
			escapes = true
		case "-E":
			escapes = false
		default:
			// not a recognized flag; stop parsing flags (POSIX behavior varies, this is practical)
			goto doneFlags
		}
		i++
	}
doneFlags:

	out := strings.Join(args[i:], " ")
	if escapes {
		out = unescape(out)
	}

	// Write to stdout
	if _, err := os.Stdout.WriteString(out); err != nil {
		fmt.Fprintln(os.Stderr, "echo:", err)
		return 1
	}
	if newline {
		if _, err := os.Stdout.WriteString("\n"); err != nil {
			fmt.Fprintln(os.Stderr, "echo:", err)
			return 1
		}
	}
	return 0
}

// unescape handles a small, useful subset of echo -e escapes:
// \n \t \\ \" \r \a \b \v \f \xHH \0NNN
func unescape(s string) string {
	var b strings.Builder
	b.Grow(len(s))
	for i := 0; i < len(s); i++ {
		c := s[i]
		if c != '\\' || i+1 >= len(s) {
			b.WriteByte(c)
			continue
		}
		// look at next
		i++
		switch s[i] {
		case 'n':
			b.WriteByte('\n')
		case 't':
			b.WriteByte('\t')
		case 'r':
			b.WriteByte('\r')
		case 'a':
			b.WriteByte('\a')
		case 'b':
			b.WriteByte('\b')
		case 'v':
			b.WriteByte('\v')
		case 'f':
			b.WriteByte('\f')
		case '\\':
			b.WriteByte('\\')
		case '"':
			b.WriteByte('"')
		case 'x':
			// hex: \xHH
			hh := takeHex(s, i+1, 2)
			if hh.n == 0 {
				// no valid hex, keep literally
				b.WriteString(`\x`)
			} else {
				b.WriteByte(byte(hh.val))
				i += hh.n
			}
		case '0':
			// octal: \0NNN (up to 3)
			oo := takeOct(s, i+1, 3)
			if oo.n == 0 {
				b.WriteByte(0)
			} else {
				b.WriteByte(byte(oo.val))
				i += oo.n
			}
		default:
			// unknown escape: keep as literal escaped char
			b.WriteByte(s[i])
		}
	}
	return b.String()
}

type dig struct {
	val int
	n   int
}

func takeHex(s string, start, max int) dig {
	end := start
	for end < len(s) && max > 0 {
		if !isHex(s[end]) {
			break
		}
		end++
		max--
	}
	if end == start {
		return dig{0, 0}
	}
	v, _ := strconv.ParseInt(s[start:end], 16, 32)
	return dig{int(v), end - start}
}

func takeOct(s string, start, max int) dig {
	end := start
	for end < len(s) && max > 0 {
		if s[end] < '0' || s[end] > '7' {
			break
		}
		end++
		max--
	}
	if end == start {
		return dig{0, 0}
	}
	v, _ := strconv.ParseInt(s[start:end], 8, 32)
	return dig{int(v), end - start}
}

func isHex(b byte) bool {
	return (b >= '0' && b <= '9') ||
		(b >= 'a' && b <= 'f') ||
		(b >= 'A' && b <= 'F')
}
